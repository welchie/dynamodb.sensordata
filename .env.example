# ==============================================================================
# Example Environment Variables Configuration for dynamodb.sensordata
# Rename this file to '.env' and populate it with your configuration.
# WARNING: Do not commit the populated '.env' file containing actual secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker Hub Credentials
# Used by Maven plugins to login and push the generated Docker images
# ------------------------------------------------------------------------------
DOCKER_USER=your_docker_username
DOCKER_PASSWORD=your_docker_password

# ------------------------------------------------------------------------------
# Spring Security Credentials
# Used to authenticate API clients accessing secured REST endpoints
# ------------------------------------------------------------------------------
SPRING_SECURITY_USER_NAME=admin_user
SPRING_SECURITY_USER_PASSWORD=secure_api_password_here

# ------------------------------------------------------------------------------
# AWS Credentials (Optional if using IAM roles in production)
# For local development with DynamoDB Local, these can be set to dummy values.
# For production cloud deployments, it is recommended to leave these empty
# and let the application fall back to the IAM task/instance role.
# ------------------------------------------------------------------------------
AMAZON_AWS_ACCESSKEY=dummyAccessKey
AMAZON_AWS_SECRETKEY=dummySecretKey
AMAZON_AWS_REGION=us-east-1
AMAZON_AWS_ENDPOINTURL=http://localhost:8000
